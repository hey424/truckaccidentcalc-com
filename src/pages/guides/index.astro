const description = 'In-depth guides on truck accident settlements: how case values are built, FMCSA rules that matter for liability, comparative fault state-by-state, and dealing with trucking insurers.';
---
<BaseLayout title={title} description={description}>
  <h1>Guides</h1>
  <p>Deeper-dive material that supports the calculator. Each guide is reviewed by our editorial team and dated; we update them when federal regulations or commonly-cited damage rules change.</p>

  <h2>The math</h2>
  <ul>
    <li><a href="/guides/how-truck-accident-settlements-are-calculated">How truck accident settlements are calculated</a> &mdash; walks through the special damages + multiplier framework with a worked example, the questions that drive multiplier selection, and the most common errors in DIY valuations.</li>
  </ul>

  <h2>The regulations</h2>
  <ul>
    <li><a href="/guides/fmcsa-trucking-regulations-explained">FMCSA trucking regulations explained</a> &mdash; the federal rules that govern commercial carriers (hours of service, driver qualifications, insurance minimums, ELD requirements) and how their violation affects civil liability.</li>
  </ul>

  <h2>The legal framework</h2>
  <ul>
    <li><a href="/guides/comparative-fault-truck-accidents">Comparative fault and truck accidents</a> &mdash; pure comparative, modified comparative, and pure contributory negligence states; how plaintiff fault reduces recovery; the cliff at 50/51% in modified comparative states.</li>
  </ul>

  <h2>The negotiation</h2>
  <ul>
    <li><a href="/guides/dealing-with-trucking-insurance">Dealing with trucking insurance companies</a> &mdash; how adjusters evaluate cases, what the early offer means, what reservation-of-rights letters mean, and the timing question (settle before or after MMI).</li>
  </ul>
